<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="512.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.demo.client.controller.RegisterController">
   <children>
      <Label layoutX="165.0" layoutY="22.0" text="Đăng ký tài khoản">
         <font>
            <Font size="28.0" />
         </font>
      </Label>

      <Label layoutX="90.0" layoutY="92.0" text="Họ và tên" />
      <TextField fx:id="fullNameField" layoutX="90.0" layoutY="110.0" prefHeight="26.0" prefWidth="320.0" promptText="Nhập họ và tên" />

      <Label layoutX="90.0" layoutY="152.0" text="Tên đăng nhập" />
      <TextField fx:id="usernameField" layoutX="90.0" layoutY="170.0" prefHeight="26.0" prefWidth="320.0" promptText="Chọn tên đăng nhập" />

      <Label layoutX="90.0" layoutY="212.0" text="Email" />
      <TextField fx:id="emailField" layoutX="90.0" layoutY="230.0" prefHeight="26.0" prefWidth="320.0" promptText="Nhập email" />

      <Label layoutX="90.0" layoutY="272.0" text="Mật khẩu" />
      <PasswordField fx:id="passwordField" layoutX="90.0" layoutY="290.0" prefHeight="26.0" prefWidth="320.0" promptText="Nhập mật khẩu" />

      <Label layoutX="90.0" layoutY="332.0" text="Xác nhận mật khẩu" />
      <PasswordField fx:id="confirmPasswordField" layoutX="90.0" layoutY="350.0" prefHeight="26.0" prefWidth="320.0" promptText="Nhập lại mật khẩu" />

      <Button fx:id="registerButton" layoutX="90.0" layoutY="405.0" mnemonicParsing="false" onAction="#handleRegisterAction" prefHeight="34.0" prefWidth="150.0" text="Tạo tài khoản" />
      <Button fx:id="backToLoginButton" layoutX="260.0" layoutY="405.0" mnemonicParsing="false" onAction="#handleBackToLogin" prefHeight="34.0" prefWidth="150.0" text="Quay lại đăng nhập" />
      <Label fx:id="messageLabel" layoutX="90.0" layoutY="454.0" prefWidth="320.0" style="-fx-text-fill: red;" />
   </children>
</AnchorPane>

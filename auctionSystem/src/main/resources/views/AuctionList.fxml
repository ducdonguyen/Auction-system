<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0" prefWidth="1200.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionListController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #0f172a; -fx-background-radius: 16;">
               <padding>
                  <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
               </padding>
               <children>
                  <VBox>
                     <children>
                        <Label text="Hệ thống Đấu giá" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label text="Danh sách các phiên đấu giá đang diễn ra" textFill="#94a3b8" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogoutAction" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8;" text="Đăng xuất">
                     <padding>
                        <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                     </padding>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <TextField fx:id="searchField" prefHeight="40.0" prefWidth="300.0" promptText="Tìm kiếm sản phẩm..." style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                  <ComboBox fx:id="statusFilter" prefHeight="40.0" prefWidth="150.0" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                  <Button mnemonicParsing="false" onAction="#handleSearchAction" prefHeight="40.0" style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-background-radius: 10;" text="Tìm kiếm">
                     <padding>
                        <Insets left="20.0" right="20.0" />
                     </padding>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleRefreshAction" prefHeight="40.0" style="-fx-background-color: #f1f5f9; -fx-text-fill: #0f172a; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" text="Làm mới">
                     <padding>
                        <Insets left="20.0" right="20.0" />
                     </padding>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="resultLabel" text="Hiển thị 0 phiên." textFill="#64748b" />
               </children>
            </HBox>
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-overflow-x: hidden;">
              <columns>
                <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="itemColumn" prefWidth="200.0" text="Sản phẩm" />
                  <TableColumn fx:id="sellerColumn" prefWidth="150.0" text="Người bán" />
                  <TableColumn fx:id="priceColumn" prefWidth="120.0" text="Giá hiện tại" />
                  <TableColumn fx:id="stepColumn" prefWidth="100.0" text="Bước giá" />
                  <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Trạng thái" />
                  <TableColumn fx:id="summaryColumn" prefWidth="350.0" text="Mô tả" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Button fx:id="openAuctionButton" mnemonicParsing="false" onAction="#handleOpenAuctionAction" prefHeight="48.0" prefWidth="200.0" style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold;" text="VÀO PHÒNG ĐẤU GIÁ">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
